{
  "name": "@docen/editor",
  "version": "0.5.3",
  "description": "Assembly layer for docen editors — bundles a Fluent UI host (ribbon, panes, status bar) with the @docen/docx engine into turnkey <docen-document> web components, with Office.js-style add-ins and Office-style pagination",
  "keywords": [
    "add-ins",
    "components",
    "docen",
    "document",
    "editor",
    "fluent-ui",
    "office",
    "office-js",
    "pagination",
    "ribbon",
    "task-pane",
    "web-components",
    "word",
    "wysiwyg"
  ],
  "homepage": "https://github.com/DemoMacro/docen#readme",
  "bugs": {
    "url": "https://github.com/DemoMacro/docen/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Demo Macro",
    "email": "abc@imst.xyz",
    "url": "https://www.demomacro.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DemoMacro/docen.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./document": {
      "types": "./dist/document/index.d.mts",
      "import": "./dist/document/index.mjs"
    },
    "./document/pagination": {
      "types": "./dist/document/pagination/index.d.mts",
      "import": "./dist/document/pagination/index.mjs"
    },
    "./workbook": {
      "types": "./dist/workbook.d.mts",
      "import": "./dist/workbook.mjs"
    },
    "./presentation": {
      "types": "./dist/presentation.d.mts",
      "import": "./dist/presentation.mjs"
    },
    "./render/*": {
      "types": "./dist/render/*.d.mts",
      "import": "./dist/render/*.mjs"
    }
  },
  "scripts": {
    "dev": "basis build --stub",
    "demo": "vp dev",
    "build": "vp pack",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.8",
    "@docen/core": "workspace:*",
    "@docen/docx": "workspace:*",
    "@fluentui/svg-icons": "1.1.333",
    "@fluentui/tokens": "1.0.0-alpha.23",
    "@fluentui/web-components": "3.0.1",
    "@microsoft/fast-element": "3.0.1",
    "@tiptap/extension-bubble-menu": "3.27.3",
    "@tiptap/extension-list": "3.27.3",
    "@tiptap/extensions": "3.27.3",
    "@tiptap/pm": "3.27.3",
    "image-meta": "0.2.2",
    "leafer-editor": "2.2.0",
    "leafer-ui": "2.2.0",
    "prosemirror-search": "1.1.1"
  }
}
