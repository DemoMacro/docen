    "office",
    "prosemirror",
    "rich-text",
    "tiptap",
    "typescript",
    "unified-api",
    "word"
  ],
  "homepage": "https://github.com/DemoMacro/docen#readme",
  "bugs": {
    "url": "https://github.com/DemoMacro/docen/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Demo Macro",
    "email": "abc@imst.xyz",
    "url": "https://www.demomacro.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DemoMacro/docen.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
